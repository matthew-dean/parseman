{
  "name": "parseman",
  "version": "0.12.0",
  "packageManager": "pnpm@10.15.1",
  "description": "Parser combinators that compile to optimized JavaScript — use as a library or as a build-time macro",
  "type": "module",
  "author": "Matthew Dean <matthew-dean@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthew-dean/parseman.git"
  },
  "homepage": "https://github.com/matthew-dean/parseman",
  "bugs": "https://github.com/matthew-dean/parseman/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts",
    "coverage:baseline": "pnpm test:coverage && node scripts/update-coverage-baseline.mjs",
    "coverage:guard": "node scripts/coverage-guard.mjs",
    "typecheck": "tsc",
    "lint": "oxlint src test examples bench",
    "bench": "node --import tsx/esm bench/run.ts",
    "bench:baseline": "node --import tsx/esm bench/update-parseman-baseline.ts",
    "perf:guard": "node --import tsx/esm bench/perf-guard.ts",
    "prepare": "git config core.hooksPath scripts/git-hooks || true",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "bench:svg": "node --import tsx/esm bench/gen-svg.ts",
    "bench:size": "node --import tsx/esm bench/measure-expansion.ts",
    "docs:favicons": "node scripts/gen-favicons.mjs",
    "build:chevrotain-bench": "node --import tsx/esm scripts/build-chevrotain-bench.mjs",
    "bench:compile-grammars": "peggy --format es -o bench/json-parser.js bench/json.pegjs && peggy --format es -o bench/csv-parser.js bench/csv.pegjs && peggy --format es -o bench/graphql-parser.js bench/graphql.pegjs && nearleyc bench/vendor/nearley/json.ne -o bench/json-nearley.cjs && nearleyc bench/vendor/nearley/csv.ne -o bench/csv-nearley.cjs && nearleyc bench/vendor/nearley/graphql.ne -o bench/graphql-nearley.cjs && node bench/compile-jison.mjs"
  },
  "keywords": [
    "parser",
    "parser-combinators",
    "macro",
    "compile-time",
    "codegen"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "~4.1.9",
    "@lezer/common": "~1.5.2",
    "@lezer/json": "~1.0.3",
    "@oxc-project/types": "~0.137.0",
    "@types/node": "~26.0.0",
    "@types/parsimmon": "~1.10.9",
    "chevrotain": "~12.0.0",
    "esbuild": "~0.27.7",
    "favicons": "~7.3.0",
    "sharp": "~0.34.5",
    "jison": "~0.4.18",
    "moo": "~0.5.3",
    "nearley": "~2.20.1",
    "oxlint": "~1.71.0",
    "parsimmon": "~1.18.1",
    "peggy": "~5.1.0",
    "tsup": "~8.5.1",
    "tsx": "~4.22.4",
    "typescript": "7.0.1-rc",
    "vite": "~8.0.16",
    "vitepress": "~1.6.4",
    "vitest": "~4.1.9",
    "xregexp": "~5.1.2"
  },
  "dependencies": {
    "magic-string": "~0.30.21",
    "oxc-parser": "~0.137.0",
    "regexp-tree": "~0.1.27",
    "unplugin": "~3.0.0"
  }
}
