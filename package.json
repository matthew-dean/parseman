{
  "name": "parseman",
  "version": "0.2.0",
  "description": "Parser combinators that compile to optimized JavaScript — use as a library or as a build-time macro",
  "type": "module",
  "author": "Matthew Dean <matthew-dean@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthew-dean/parseman.git"
  },
  "homepage": "https://github.com/matthew-dean/parseman",
  "bugs": "https://github.com/matthew-dean/parseman/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "bench": "node --import tsx/esm bench/run.ts",
    "bench:compile-grammars": "peggy --format es -o bench/json-parser.js bench/json.pegjs && peggy --format es -o bench/csv-parser.js bench/csv.pegjs && peggy --format es -o bench/graphqlite-parser.js bench/graphqlite.pegjs"
  },
  "keywords": [
    "parser",
    "parser-combinators",
    "macro",
    "compile-time",
    "codegen"
  ],
  "license": "MIT",
  "devDependencies": {
    "@oxc-project/types": "~0.137.0",
    "@types/node": "~26.0.0",
    "@types/parsimmon": "~1.10.9",
    "chevrotain": "~12.0.0",
    "esbuild": "~0.28.1",
    "parsimmon": "~1.18.1",
    "peggy": "~5.1.0",
    "tsup": "~8.5.1",
    "tsx": "~4.22.4",
    "typescript": "7.0.1-rc",
    "vite": "~8.0.16",
    "vitest": "~4.1.9",
    "xregexp": "~5.1.2"
  },
  "dependencies": {
    "magic-string": "~0.30.21",
    "oxc-parser": "~0.137.0",
    "regexp-tree": "~0.1.27",
    "unplugin": "~3.0.0"
  }
}
