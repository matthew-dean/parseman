{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "erasableSyntaxOnly": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*", "test/**/*"],
  // test/fixtures holds macro *input source* (read as text by the plugin resolver
  // and run via `new Function`), not app code: it imports bare 'parseman' and uses
  // intentionally untyped callbacks, so it isn't type-checkable standalone.
  "exclude": ["node_modules", "dist", "test/fixtures"]
}
